# =============================================================
# SHARED (used across apps/services)
# =============================================================
APP_URL=http://localhost:3000

# Chain/network shared settings
CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
COOP_FACTORY_ADDRESS=REPLACE_AFTER_CONTRACT_DEPLOY
GAS_RELAYER_ADDRESS=REPLACE_AFTER_CONTRACT_DEPLOY
NEXT_PUBLIC_CELOSCAN_BASE=https://celo-sepolia.blockscout.com
NEXT_PUBLIC_CELO_CHAIN=celoSepolia

# Public API endpoints consumed by clients
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
NEXT_PUBLIC_GRAPHQL_WS_URL=ws://localhost:4000/graphql

# Firebase client SDK shared with frontend/mobile
NEXT_PUBLIC_FIREBASE_API_KEY=REPLACE_WITH_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=REPLACE.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=REPLACE_WITH_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=REPLACE.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=REPLACE_WITH_APP_ID
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=REPLACE_WITH_MEASUREMENT_ID
NEXT_PUBLIC_FIREBASE_VAPID_KEY=REPLACE_WITH_FIREBASE_VAPID_KEY

# =============================================================
# BACKEND ONLY
# =============================================================
BLOCKCHAIN_ENABLED=true
API_PORT=4000

# Database (Supabase example)
# Use URL-encoded password only (not whole URL)
DATABASE_URL=postgresql://postgres.PROJECT_REF:REPLACE_WITH_ENCODED_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:REPLACE_WITH_ENCODED_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# Redis / cache
REDIS_URL=https://REPLACE_WITH_UPSTASH_REDIS_URL

# Auth (legacy names kept to match current production env)
NEXTAUTH_SECRET=REPLACE_WITH_MIN_32_CHAR_SECRET
NEXTAUTH_URL=http://localhost:3000

# Optional new aliases supported by backend code
AUTH_SECRET=REPLACE_WITH_MIN_32_CHAR_SECRET
AUTH_URL=http://localhost:3000

# Celo relayer and encryption
CELO_RELAYER_PRIVATE_KEY=REPLACE_WITH_GENERATED_PRIVATE_KEY
CELO_RELAYER_PUBLIC_KEY=REPLACE_WITH_GENERATED_PUBLIC_KEY
ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHAR_KEY

# CamPay
CAMPAY_API_KEY=REPLACE_WITH_CAMPAY_KEY
CAMPAY_WEBHOOK_SECRET=REPLACE_WITH_CAMPAY_WEBHOOK_SECRET
CAMPAY_BASE_URL=https://demo.campay.net/api
CAMPAY_TRANSFER_API_KEY=REPLACE_WITH_CAMPAY_TRANSFER_KEY
CAMPAY_WEBHOOK_URL=http://localhost:4000/payments/webhook

# AWS S3 (name kept as S3_REGION to avoid Vercel reserved-name conflicts)
AWS_S3_BUCKET=coopenergie-files
AWS_ACCESS_KEY=REPLACE_WITH_AWS_ACCESS_KEY
AWS_SECRET_KEY=REPLACE_WITH_AWS_SECRET_KEY
S3_REGION=eu-west-1

# Firebase service account (server side)
FIREBASE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE\n-----END PRIVATE KEY-----\n"
FIREBASE_SERVICE_ACCOUNT_CLIENT_EMAIL=firebase-adminsdk-xxxxx@REPLACE.iam.gserviceaccount.com

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=REPLACE_WITH_SMTP_EMAIL
SMTP_PASS=REPLACE_WITH_SMTP_PASSWORD_OR_APP_PASSWORD
EMAIL_FROM="CoopEnergie <noreply@example.com>"

# =============================================================
# FRONTEND ONLY (web)
# =============================================================
# Web app currently consumes the NEXT_PUBLIC_* keys from SHARED above.
# Add frontend-only private vars here if/when introduced.
