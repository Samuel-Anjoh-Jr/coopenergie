# ── BLOCKCHAIN ────────────────────────────────────────────────
BLOCKCHAIN_ENABLED=true          # set false to skip on-chain calls in dev

# ── DATABASE ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coopenergie
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/coopenergie

# ── REDIS ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AUTH ──────────────────────────────────────────────────────
NEXTAUTH_SECRET=REPLACE_WITH_MIN_32_CHAR_SECRET
NEXTAUTH_URL=http://localhost:3000

# ── BACKEND ───────────────────────────────────────────────────
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
NEXT_PUBLIC_GRAPHQL_WS_URL=ws://localhost:4000/graphql

# ── CELO ──────────────────────────────────────────────────────
# Testnet: https://alfajores-forno.celo-testnet.org
# Mainnet: https://forno.celo.org
CELO_RPC_URL=https://alfajores-forno.celo-testnet.org
CELO_RELAYER_PRIVATE_KEY=REPLACE_WITH_GENERATED_PRIVATE_KEY
COOP_FACTORY_ADDRESS=REPLACE_AFTER_CONTRACT_DEPLOY
GAS_RELAYER_ADDRESS=REPLACE_AFTER_CONTRACT_DEPLOY

# ── CELOSCAN ──────────────────────────────────────────────────
# Testnet: https://alfajores.celoscan.io
# Mainnet: https://celoscan.io
NEXT_PUBLIC_CELOSCAN_BASE=https://alfajores.celoscan.io
NEXT_PUBLIC_CELO_CHAIN=alfajores
ENCRYPTION_KEY=REPLACE_WITH_ENCRYPTION_KEY # (64 hex chars) Generate via: # Node.js "node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"" # OpenSSL "openssl rand -hex 32"

# ── CAMPAY ────────────────────────────────────────────────────
# Sandbox: https://demo.campay.net/api
# Production: https://www.campay.net/api
CAMPAY_API_KEY=REPLACE_WITH_CAMPAY_KEY
CAMPAY_WEBHOOK_SECRET=REPLACE_WITH_CAMPAY_WEBHOOK_SECRET
CAMPAY_BASE_URL=https://demo.campay.net/api
# CamPay disbursement / transfer API key (may be same as collection key)
CAMPAY_TRANSFER_API_KEY=REPLACE_WITH_CAMPAY_TRANSFER_KEY

# ── AWS S3 ────────────────────────────────────────────────────
AWS_S3_BUCKET=coopenergie-files
AWS_ACCESS_KEY=REPLACE
AWS_SECRET_KEY=REPLACE
AWS_REGION=eu-west-1

# ── FIREBASE ──────────────────────────────────────────────────
FIREBASE_SERVER_KEY=REPLACE_WITH_FIREBASE_KEY
# Firebase Service Account (from Project Settings > Service Accounts > Generate key)
# Download the JSON, then extract these two fields:
FIREBASE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE\n-----END PRIVATE KEY-----\n"
FIREBASE_SERVICE_ACCOUNT_CLIENT_EMAIL=firebase-adminsdk-xxxxx@coopenergie-prod.iam.gserviceaccount.com

# ── EMAIL (Nodemailer / SMTP) ─────────────────────────────────
# Use Gmail SMTP, Mailgun, SendGrid, or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false          # true for port 465, false for 587
SMTP_USER=REPLACE_WITH_SMTP_EMAIL
SMTP_PASS=REPLACE_WITH_SMTP_PASSWORD_OR_APP_PASSWORD
EMAIL_FROM="CoopEnergie <noreply@coopenergie.cm>"

# ── PLATFORM ──────────────────────────────────────────────────
APP_URL=http://localhost:3000
