{
  "compilerOptions": {
    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["node", "hardhat"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "scripts/**/*.ts",
    "test/**/*.ts",
    "index.ts",
    "hardhat.config.cjs",
    "typechain-types/**/*.ts"
  ]
}
