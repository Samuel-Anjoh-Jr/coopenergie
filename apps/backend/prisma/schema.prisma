datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}


generator client {
  provider = "prisma-client-js"
}

enum Role {
  PLATFORM_ADMIN
  COOP_ADMIN
  MEMBER
  VENDOR
}

enum InvitationType {
  EMAIL
  LINK
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum ContributionStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentProvider {
  CAMPAY
}

enum LedgerEventType {
  CONTRIBUTION
  VOTE
  PROPOSAL
  PAYMENT
  MEMBERSHIP
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum BillingCycle {
  FREE
  ONE_TIME
  MONTHLY
  YEARLY
}

enum DevicePlatform {
  WEB
  IOS
  ANDROID
}

enum WithdrawalStatus {
  PENDING_VOTE
  APPROVED
  REJECTED
  DISBURSING
  DISBURSED
  FAILED
}

enum WithdrawalDestinationType {
  MTN_MOMO
  ORANGE_MONEY
  BANK_TRANSFER
}

enum ProposalType {
  STANDARD
  WITHDRAWAL
  VENDOR_PURCHASE
}

enum VendorPaymentModel {
  ONE_TIME
  SUBSCRIPTION
}

enum VendorSubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum VendorAccountStatus {
  PENDING_PAYMENT
  ACTIVE
  SUSPENDED
  SUBSCRIPTION_EXPIRED
}

model User {
  id                     String         @id @default(cuid())
  email                  String         @unique
  passwordHash           String
  name                   String
  role                   Role           @default(MEMBER)
  suspended              Boolean        @default(false)
  isPlatformAdmin        Boolean        @default(false)
  celoAddress            String?        @unique
  celoKeyEncrypted       String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  memberships            Membership[]
  contributions          Contribution[]
  proposals              Proposal[]
  votes                  Vote[]
  auditLogs              AuditLog[]
  deviceTokens           DeviceToken[]
  withdrawalPhone        String?
  withdrawalOperator     String?
  withdrawalBankName     String?
  withdrawalBankAccount  String?
  preferredLocale        String         @default("fr")
  vendor                 Vendor?
}

model Cooperative {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  suspended            Boolean               @default(false)
  withdrawalsLocked    Boolean               @default(false)
  baseTargetXAF        Int?
  targetAmountXAF      Int
  vaultAddress         String?
  celoScanUrl          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  memberships          Membership[]
  contributions        Contribution[]
  proposals            Proposal[]
  ledgerEvents         LedgerEvent[]
  payments             Payment[]
  invitations          Invitation[]
  subscriptions        Subscription[]
  auditLogs            AuditLog[]
  settings             CooperativeSettings?
  confirmedBalanceXAF  Int                   @default(0)
  withdrawalRequests   WithdrawalRequest[]
  vaultAdminAddress    String?               // Persisted on-chain admin address for diagnostics
}

model Membership {
  id            String      @id @default(cuid())
  userId        String
  cooperativeId String
  role          Role        @default(MEMBER)
  joinedAt      DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cooperative   Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)

  @@unique([userId, cooperativeId])
}

model Invitation {
  id            String           @id @default(cuid())
  email         String?
  token         String           @unique @default(cuid())
  cooperativeId String
  type          InvitationType   @default(EMAIL)
  status        InvitationStatus @default(PENDING)
  expiresAt     DateTime
  createdAt     DateTime         @default(now())
  cooperative   Cooperative      @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
}

model Contribution {
  id            String             @id @default(cuid())
  amountXAF     Int
  userId        String
  cooperativeId String
  txHash        String?
  blockNumber   Int?
  status        ContributionStatus @default(PENDING)
  paymentId     String?            @unique
  createdAt     DateTime           @default(now())
  user          User               @relation(fields: [userId], references: [id])
  cooperative   Cooperative        @relation(fields: [cooperativeId], references: [id])
  payment       Payment?           @relation(fields: [paymentId], references: [id])
}

model Proposal {
  id                String              @id @default(cuid())
  title             String
  description       String
  status            ProposalStatus      @default(PENDING)
  cooperativeId     String
  creatorId         String
  txHash            String?
  blockNumber       Int?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  votes             Vote[]
  creator           User                @relation(fields: [creatorId], references: [id])
  cooperative       Cooperative         @relation(fields: [cooperativeId], references: [id])
  type              ProposalType        @default(STANDARD)
  withdrawalRequest WithdrawalRequest?
  vendorLink        ProposalVendorLink?
}

model Vote {
  id          String   @id @default(cuid())
  userId      String
  proposalId  String
  choice      Boolean
  txHash      String?
  blockNumber Int?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  proposal    Proposal @relation(fields: [proposalId], references: [id])

  @@unique([userId, proposalId])
}

model LedgerEvent {
  id            String          @id @default(cuid())
  type          LedgerEventType
  payload       Json
  txHash        String          @unique
  blockNumber   Int
  cooperativeId String
  createdAt     DateTime        @default(now())
  cooperative   Cooperative     @relation(fields: [cooperativeId], references: [id])
}

model Payment {
  id             String          @id @default(cuid())
  amountXAF      Int
  userId         String
  cooperativeId  String
  status         PaymentStatus   @default(PENDING)
  provider       PaymentProvider @default(CAMPAY)
  reference      String          @unique
  idempotencyKey String          @unique
  phoneNumber    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  cooperative    Cooperative     @relation(fields: [cooperativeId], references: [id])
  contribution   Contribution?
}

model WithdrawalRequest {
  id                   String                    @id @default(cuid())
  cooperativeId        String
  proposalId           String                    @unique
  amountXAF            Int
  platformFeeXAF       Int                       @default(0)
  destinationType      WithdrawalDestinationType
  recipientPhone       String?
  recipientOperator    String?
  recipientBankName    String?
  recipientBankAccount String?
  recipientName        String
  campayReference      String?
  failureReason        String?
  status               WithdrawalStatus          @default(PENDING_VOTE)
  disbursedAt          DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  cooperative          Cooperative               @relation(fields: [cooperativeId], references: [id])
  proposal             Proposal                  @relation(fields: [proposalId], references: [id])
}

model PlatformSettings {
  id                         String             @id @default("singleton")
  withdrawalThresholdDefault Int                @default(60)
  withdrawalThresholdMin     Int                @default(50)
  withdrawalThresholdMax     Int                @default(90)
  withdrawalQuorumMinVotes   Int                @default(3)
  maintenanceMode            Boolean            @default(false)
  platformName               String             @default("CoopEnergie")
  appStoreUrl                String?
  playStoreUrl               String?
  updatedAt                  DateTime           @updatedAt
  updatedById                String?
  withdrawalFeePercent       Float              @default(0)
  vendorPaymentModel         VendorPaymentModel @default(ONE_TIME)
  vendorOneTimeFeeXAF        Int                @default(0)
  vendorMonthlyFeeXAF        Int                @default(0)
  vendorYearlyFeeXAF         Int                @default(0)
}

model CooperativeSettings {
  id                  String      @id @default(cuid())
  cooperativeId       String      @unique
  withdrawalThreshold Int         @default(60)
  cooperative         Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
}

model Plan {
  id            String         @id @default(cuid())
  name          String         @unique
  priceXAF      Int
  billingCycle  BillingCycle   @default(FREE)
  features      Json           @default("{}")
  subscriptions Subscription[]
}

model Subscription {
  id            String             @id @default(cuid())
  cooperativeId String
  planId        String
  status        SubscriptionStatus @default(ACTIVE)
  expiresAt     DateTime?
  createdAt     DateTime           @default(now())
  cooperative   Cooperative        @relation(fields: [cooperativeId], references: [id])
  plan          Plan               @relation(fields: [planId], references: [id])
}

model AuditLog {
  id            String       @id @default(cuid())
  userId        String?
  cooperativeId String?
  action        String
  entity        String
  entityId      String?
  metadata      Json         @default("{}")
  createdAt     DateTime     @default(now())
  user          User?        @relation(fields: [userId], references: [id])
  cooperative   Cooperative? @relation(fields: [cooperativeId], references: [id])
}

model DeviceToken {
  id        String         @id @default(cuid())
  userId    String
  token     String         @unique
  platform  DevicePlatform
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vendor {
  id             String              @id @default(cuid())
  userId         String              @unique
  campayRegistrationRef String?      @unique
  businessName   String
  slug           String              @unique
  description    String              @db.Text
  logoUrl        String?
  coverImageUrl  String?
  city           String?
  country        String              @default("CM")
  email          String?
  whatsappNumber String?
  website        String?
  facebookUrl    String?
  instagramUrl   String?
  twitterUrl     String?
  linkedinUrl    String?
  status         VendorAccountStatus @default(PENDING_PAYMENT)
  paymentModel   VendorPaymentModel  @default(ONE_TIME)
  rankScore      Float               @default(0)
  totalReviews   Int                 @default(0)
  avgRating      Float               @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  products       VendorProduct[]
  subscriptions  VendorSubscriptionRecord[]
  reviews        VendorReview[]
  proposalLinks  ProposalVendorLink[]
}

model VendorProduct {
  id            String               @id @default(cuid())
  vendorId      String
  title         String
  description   String               @db.Text
  priceXAF      Int
  unit          String?
  inStock       Boolean              @default(true)
  sortOrder     Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  vendor        Vendor               @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  images        VendorProductImage[]
  proposalLinks ProposalVendorLink[]
}

model VendorProductImage {
  id        String        @id @default(cuid())
  productId String
  url       String
  altText   String?
  sortOrder Int           @default(0)
  product   VendorProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProposalVendorLink {
  id         String         @id @default(cuid())
  proposalId String         @unique
  vendorId   String
  productId  String?
  note       String?        @db.Text
  proposal   Proposal       @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  vendor     Vendor         @relation(fields: [vendorId], references: [id])
  product    VendorProduct? @relation(fields: [productId], references: [id])
}

model VendorReview {
  id            String   @id @default(cuid())
  vendorId      String
  reviewerId    String
  cooperativeId String
  proposalId    String
  rating        Int
  comment       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  vendor        Vendor   @relation(fields: [vendorId], references: [id])

  @@unique([reviewerId, proposalId])
}

model VendorSubscriptionRecord {
  id              String                   @id @default(cuid())
  vendorId        String
  billingCycle    String
  priceXAF        Int
  status          VendorSubscriptionStatus @default(PENDING)
  campayReference String?                  @unique
  startedAt       DateTime?
  expiresAt       DateTime?
  createdAt       DateTime                 @default(now())
  vendor          Vendor                   @relation(fields: [vendorId], references: [id])
}

enum FaqAudience {
  CUSTOMER
  VENDOR
}

model Faq {
  id        String      @id @default(cuid())
  question  String
  answer    String      @db.Text
  audience  FaqAudience
  sortOrder Int         @default(0)
  locale    String      @default("fr")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}
