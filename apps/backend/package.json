{
  "name": "@coopenergie/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --max-old-space-size=4096 ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "build": "bunx tsc -p tsconfig.json",
    "start": "node dist/main",
    "lint": "eslint src --ext .ts",
    "typecheck": "bunx prisma generate --schema prisma/schema.prisma && tsc --noEmit",
    "prisma:seed": "bun run src/prisma/seed.ts",
    "migrate:vault": "bun run src/prisma/migrate-cooperative-vault.ts"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@nestjs/apollo": "^13.4.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "3.0.1",
    "@nestjs/graphql": "^13.4.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "5.22.0",
    "@smithy/node-http-handler": "^4.4.5",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "ethers": "^6.15.0",
    "expo-server-sdk": "^6.1.0",
    "firebase-admin": "^13.8.0",
    "graphql": "^16.13.2",
    "graphql-scalars": "^1.25.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-ws": "^6.0.8",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.2",
    "rxjs": "^7.8.2",
    "subscriptions-transport-ws": "^0.11.0",
    "viem": "^2.48.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.2.8",
    "@angular-devkit/schematics": "^21.2.8",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.6.0",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "5.4.5"
  }
}
